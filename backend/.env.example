# Kopiraj u .env i popuni vrednosti

# Produkcija
SECRET_KEY=generisi-dugi-random-string
DEBUG=False
ALLOWED_HOSTS=tvoj-app.onrender.com
DATABASE_URL=postgresql://user:pass@host/dbname
CORS_ALLOWED_ORIGINS=https://tvoj-front.vercel.app

# Lokalni razvoj (defaultne vrednosti, .env nije ni potreban lokalno)
# DEBUG=True
# DB_NAME=paws_db
# DB_USER=paws_user
# DB_PASSWORD=paws_password
# DB_HOST=localhost
# DB_PORT=5432
