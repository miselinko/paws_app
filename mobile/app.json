{
  "expo": {
    "name": "Paws",
    "slug": "paws-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/logo.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.paws.mobile"
    },
    "android": {
      "package": "com.paws.mobile",
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#00BF8F"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Aplikacija pristupa galeriji da bi dodala sliku psa."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Aplikacija koristi lokaciju za pronalazak šetača u blizini."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "dab3d91e-1e27-423f-937e-098c3085ec28"
      }
    }
  }
}
